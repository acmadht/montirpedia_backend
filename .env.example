# DOKU Production
# Ambil dari DOKU Dashboard bagian API Keys.
DOKU_CLIENT_ID=MCH-xxxxxxxxxxxxxxxx
DOKU_SECRET_KEY=isi_secret_key_production
DOKU_BASE_URL=https://api.doku.com

# URL publik backend kamu.
# Contoh Vercel:
# https://montirpedia-backend.vercel.app/api/doku-notification
DOKU_NOTIFICATION_URL=https://domain-backend-kamu.com/api/doku-notification
DOKU_NOTIFICATION_TARGET=/api/doku-notification

# URL result/callback. Untuk aplikasi mobile, boleh isi landing page sederhana dulu.
DOKU_CALLBACK_URL=https://domain-kamu.com/payment-result

# Durasi expired checkout DOKU dalam menit.
DOKU_PAYMENT_DUE_DATE_MINUTES=60

# Firestore / Firebase Admin
# Pilihan paling praktis: encode service account JSON menjadi base64.
# Windows PowerShell:
# [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=isi_base64_service_account_json

# Alternatif jika tidak pakai base64:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Keamanan token Firebase dari Flutter.
# true = wajib verifikasi Authorization: Bearer <Firebase ID Token>
# false = tidak wajib, tetapi tetap diverifikasi bila token tersedia.
REQUIRE_FIREBASE_AUTH=false

# Jangan aktifkan ini di production kecuali sedang debugging webhook.
DOKU_SKIP_SIGNATURE_VERIFY=false
